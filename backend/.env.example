# Server
PORT=5000
NODE_ENV=development

# Database (เลือกใช้อันใดอันหนึ่ง)
# --- MySQL ---
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=narasing_billing

# --- MongoDB ---
# MONGO_URI=mongodb://localhost:27017/narasing_billing

# CORS (คั่นหลาย origin ด้วย comma)
# Development: http://localhost:5173 หรือ http://localhost:3000
# Production: ใส่ URL หน้าเว็บจริง เช่น https://your-app.vercel.app
CORS_ORIGIN=http://localhost:5173

# LINE Login (สำหรับปุ่มยืนยัน LINE ในฟอร์มจอง)
# Channel ID ตั้งค่าใน Admin > ตั้งค่าทั่วไป > LINE Login Channel ID
# Channel Secret ใส่ที่นี่ (ห้ามแชร์)
LINE_CHANNEL_ID=your_line_login_channel_id
LINE_CHANNEL_SECRET=your_line_login_channel_secret
LINE_CALLBACK_URL=http://localhost:3000/line-callback

# LINE Messaging API (สำหรับแจ้งเตือนผู้เช่าทาง LINE)
# สร้าง/ใช้ Channel ประเภท Messaging API แล้วนำ Channel access token (long-lived) มาใส่ที่นี่
LINE_MESSAGE_ACCESS_TOKEN=n+1yDxfbDz4PXr8whiqHuJUiJEwRQzQgbOLSeh9n52xXESx9wP8V2ejVG6nF7C9sYY7I2vp/JNdzCaRBIvHQsMceX7GQ4HJ6HXZnmuIGVlnxmRI7qFdoflgmHLLzO9AqP5Byhm1JfVZd21d3oNU/2wdB04t89/1O/w1cDnyilFU=